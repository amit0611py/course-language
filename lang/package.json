{
  "name": "content-engine-api",
  "version": "1.0.0",
  "description": "Content Engine backend for Interactive Programming Learning Platform",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node seeder/index.js",
    "seed:lang": "node seeder/index.js --lang",
