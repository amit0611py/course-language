    "@fastify/static": "^6.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "nodemon": "^3.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
